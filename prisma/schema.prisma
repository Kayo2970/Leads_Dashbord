// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String      @id @default(uuid())
  email           String      @unique
  fullName        String
  password        String?     // Hashed password
  isAdmin         Boolean     @default(false)
  role            String      // super_admin, faculty_admin, student_member
  designation     String?
  profilePicture  String?
  permissions     String?     // JSON string for granular access
  committees      Committee[] // Many-to-many relationship
  
  createdEvents       Event[]        @relation("EventCreator")
  createdTasks        Task[]         @relation("TaskCreator")
  assignedTasks       TaskAssignment[]
  receivedRatings     Rating[]       @relation("RatingSubject")
  givenRatings        Rating[]       @relation("RatingGiver")
  receivedContributions Contribution[] @relation("ContributionSubject")
  loggedContributions Contribution[] @relation("ContributionLogger")
  announcements       Announcement[] @relation("AnnouncementCreator")
  eventAssignments    EventAssignment[]
  
  createdAt       DateTime    @default(now())
}

model GroupPolicy {
  id          String   @id @default("global")
  menuConfig  String   // JSON string defining which roles see which menus
  updatedAt   DateTime @updatedAt
}

model Committee {
  id            String         @id @default(uuid())
  name          String
  type          String         @default("DIVISION") // ADVISORY, CORE, DIVISION
  description   String?
  users         User[]
  tasks         Task[]
  announcements Announcement[]
}

model Event {
  id            String         @id @default(uuid())
  name          String
  date          DateTime
  time          String?
  venue         String?
  description   String?
  createdBy     String
  creator       User           @relation("EventCreator", fields: [createdBy], references: [id])
  createdAt     DateTime       @default(now())
  tasks         Task[]
  contributions Contribution[]
  teamAssignments EventAssignment[]
}

model EventAssignment {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  designation String?  // Specific role for this event
  assignedAt  DateTime @default(now())

  @@unique([eventId, userId])
}

model Task {
  id            String    @id @default(uuid())
  title         String
  description   String?
  status        String    @default("pending") // pending, in-progress, completed
  priority      String    @default("medium")  // low, medium, high
  deadline      DateTime?
  
  eventId       String?
  event         Event?    @relation(fields: [eventId], references: [id])
  committeeId   String?
  committee     Committee? @relation(fields: [committeeId], references: [id])
  
  createdBy     String
  creator       User      @relation("TaskCreator", fields: [createdBy], references: [id])
  
  assignees     TaskAssignment[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  ratings       Rating[]
}

model TaskAssignment {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  role        String   @default("MEMBER") // LEAD, MEMBER, SPOC, etc.
  assignedAt  DateTime @default(now())

  @@unique([taskId, userId])
}

model Rating {
  id            String   @id @default(uuid())
  taskId        String?
  task          Task?    @relation(fields: [taskId], references: [id])
  subjectId     String
  subject       User     @relation("RatingSubject", fields: [subjectId], references: [id])
  score         Int      // Overall score 1-5
  communication Int      @default(3) // 1-5
  punctuality   Int      @default(3) // 1-5
  quality       Int      @default(3) // 1-5
  feedback      String?
  giverId       String
  giver         User     @relation("RatingGiver", fields: [giverId], references: [id])
  createdAt     DateTime @default(now())
}

model Contribution {
  id            String   @id @default(uuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id])
  memberId      String
  member        User     @relation("ContributionSubject", fields: [memberId], references: [id])
  description   String
  loggedBy      String
  logger        User     @relation("ContributionLogger", fields: [loggedBy], references: [id])
  loggedAt      DateTime @default(now())
}

model Announcement {
  id            String     @id @default(uuid())
  title         String
  body          String
  target        String     // all, committee
  committeeId   String?
  committee     Committee? @relation(fields: [committeeId], references: [id])
  createdBy     String
  creator       User       @relation("AnnouncementCreator", fields: [createdBy], references: [id])
  createdAt     DateTime   @default(now())
}
